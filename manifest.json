{
  "manifest_version": 3,
  "name": "LeetPush – LeetCode to GitHub Sync",
  "version": "1.0.0",
  "description": "Automatically push your LeetCode accepted solutions to GitHub after every successful submission.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "notifications"
  ],
  "host_permissions": [
    "https://leetcode.com/*",
    "https://api.github.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/inject.js", "src/content.js"],
      "matches": ["https://leetcode.com/*"]
    }
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/*"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
